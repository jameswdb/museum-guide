<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 AI 模型配置"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择AI模型并配置API密钥，未配置时自动使用内置中文描述"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp" />

        <!-- Provider selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择 AI 模型"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            style="@style/Widget.MaterialComponents.CardView">

            <RadioGroup
                android:id="@+id/rg_ai_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <RadioButton
                    android:id="@+id/rb_gemini"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Google Gemini 2.0 Flash（支持图片识别）"
                    android:textSize="14sp"
                    android:padding="6dp" />

                <RadioButton
                    android:id="@+id/rb_deepseek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DeepSeek（深度求索，超低价）"
                    android:textSize="14sp"
                    android:padding="6dp" />

                <RadioButton
                    android:id="@+id/rb_qwen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="通义千问 Qwen（阿里云，新用户7000万免费Token）"
                    android:textSize="14sp"
                    android:padding="6dp" />

                <RadioButton
                    android:id="@+id/rb_ernie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="文心一言 ERNIE（百度千帆，永久免费）"
                    android:textSize="14sp"
                    android:padding="6dp" />

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <!-- API Key input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/api_key_input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Key"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Model name (for non-Gemini providers) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/model_name_input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="模型名称（可选，默认值即可）"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_model_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_ai_config"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="保存配置"
            android:textSize="16sp" />

        <!-- API key hint -->
        <TextView
            android:id="@+id/tv_api_key_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:textColor="#999999"
            android:lineSpacingExtra="2sp"
            android:text="💡 Gemini: https://aistudio.google.com/apikey\n💡 DeepSeek: https://platform.deepseek.com\n💡 通义千问: https://bailian.console.aliyun.com（新用户7000万免费Token）\n💡 文心一言: https://console.bce.baidu.com/qianfan（ERNIE-Speed永久免费）" />

    </LinearLayout>

</ScrollView>
