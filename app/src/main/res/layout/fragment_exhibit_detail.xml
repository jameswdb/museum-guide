<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Exhibit image placeholder -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/exhibit_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"
                android:contentDescription="@string/exhibit_detail" />

        </androidx.cardview.widget.CardView>

        <!-- Exhibit name -->
        <TextView
            android:id="@+id/exhibit_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/on_background" />

        <!-- Era / Dynasty -->
        <TextView
            android:id="@+id/exhibit_era"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="16sp"
            android:textColor="#666666" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#DDDDDD" />

        <!-- Full description -->
        <TextView
            android:id="@+id/exhibit_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:textColor="@color/on_background"
            android:lineSpacingExtra="6sp" />

        <!-- Cultural significance -->
        <TextView
            android:id="@+id/exhibit_significance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textColor="#444444"
            android:lineSpacingExtra="4sp"
            android:padding="12dp"
            android:background="#F0F0F0" />

        <!-- Listen button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_listen"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="播放语音讲解"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_media_play" />

    </LinearLayout>

</ScrollView>
