<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome_message"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- ── Museum Location Section ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            style="@style/Widget.MaterialComponents.CardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 当前博物馆"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/location_input_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="博物馆所在城市"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_museum_city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="北京"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_current_museum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="当前定位：北京 · 故宫博物院"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_location"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="保存设置"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_gps_locate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📡 自动定位"
                        app:icon="@android:drawable/ic_menu_mylocation" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── AI Model Configuration Section ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            style="@style/Widget.MaterialComponents.CardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI 模型配置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background"
                    android:layout_marginBottom="12dp" />

                <!-- Provider selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI 模型"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/rg_ai_provider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rb_gemini"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Google Gemini 2.0 Flash（支持图片识别）"
                        android:textSize="14sp"
                        android:padding="4dp" />

                    <RadioButton
                        android:id="@+id/rb_deepseek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DeepSeek（深度求索，超低价）"
                        android:textSize="14sp"
                        android:padding="4dp" />

                    <RadioButton
                        android:id="@+id/rb_qwen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="通义千问 Qwen（阿里云，新用户7000万免费Token）"
                        android:textSize="14sp"
                        android:padding="4dp" />

                    <RadioButton
                        android:id="@+id/rb_ernie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="文心一言 ERNIE（百度千帆，永久免费）"
                        android:textSize="14sp"
                        android:padding="4dp" />

                </RadioGroup>

                <!-- API Key input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="API Key"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/api_key_input_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入所选模型的API Key"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:passwordToggleEnabled="true"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Model/endpoint config (optional) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/model_name_input_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="模型名称（可选，默认值即可）"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_model_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btn_save_ai_config"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="保存AI配置"
                    android:layout_gravity="end"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- Key hint text -->
                <TextView
                    android:id="@+id/tv_api_key_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:lineSpacingExtra="2sp"
                    android:text="💡 Gemini: https://aistudio.google.com/apikey\n💡 DeepSeek: https://platform.deepseek.com\n💡 通义千问: https://bailian.console.aliyun.com（新用户7000万免费Token）\n💡 文心一言: https://console.bce.baidu.com/qianfan（ERNIE-Speed永久免费）" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Top 10 Museums Section ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            style="@style/Widget.MaterialComponents.CardView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏛️ 中国十大博物馆"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="点击了解博物馆详情和镇馆之宝"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_museums"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Version info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="博物馆导游 v1.2"
            android:textSize="12sp"
            android:textColor="#BBBBBB"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
